{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Surfisle",
  "version": "1.0.3",
  "identifier": "com.ryancy.surfisle",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Surfisle",
        "width": 820,
        "height": 460,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "ryancy",
    "homepage": "https://github.com/beginner1868",
    "copyright": "Copyright (c) 2026 ryancy. All rights reserved.",
    "license": "LicenseRef-Surfisle-Source-Available-1.0",
    "licenseFile": "../LICENSE",
    "shortDescription": "Surfisle, a Windows floating island by ryancy.",
    "longDescription": "Surfisle is a Windows desktop productivity tool designed and developed by ryancy.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
